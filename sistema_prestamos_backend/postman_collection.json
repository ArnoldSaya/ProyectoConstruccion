{
  "info": {
    "name": "Sistema Prestamos API",
    "description": "Coleccion completa de endpoints del backend. Usar variable {{base_url}} = http://127.0.0.1:5000/api. El login automatico asigna el token a {{jwt_token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:5000/api" },
    { "key": "jwt_token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Usuario Test\",\n  \"email\": \"test@ejemplo.com\",\n  \"password\": \"123456\",\n  \"phone\": \"999888777\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"]}
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@ejemplo.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
          }
        },
        {
          "name": "Mi perfil (requiere token)",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"]}
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Listar usuarios (paginado)",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/users?page=1&per_page=10", "host": ["{{base_url}}"], "path": ["users"], "query": [
              {"key": "page", "value": "1"}, {"key": "per_page", "value": "10"}
            ]}
          }
        },
        {
          "name": "Obtener usuario por ID",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/users/1", "host": ["{{base_url}}"], "path": ["users", "1"]}
          }
        },
        {
          "name": "Crear usuario (requiere token)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Nuevo Usuario\",\n  \"email\": \"nuevo@ejemplo.com\",\n  \"password\": \"123456\",\n  \"phone\": \"111222333\"\n}"
            },
            "url": {"raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"]}
          }
        },
        {
          "name": "Actualizar usuario (requiere token)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Nombre Actualizado\",\n  \"phone\": \"444555666\"\n}"
            },
            "url": {"raw": "{{base_url}}/users/1", "host": ["{{base_url}}"], "path": ["users", "1"]}
          }
        },
        {
          "name": "Eliminar usuario (requiere token)",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{base_url}}/users/1", "host": ["{{base_url}}"], "path": ["users", "1"]}
          }
        }
      ]
    },
