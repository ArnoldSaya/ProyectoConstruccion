        {
          "name": "Crear producto (requiere token)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"owner_id\": 1,\n  \"name_prod\": \"Laptop HP\",\n  \"description\": \"Laptop para trabajo\",\n  \"category_id\": \"ID_CATEGORIA\",\n  \"price\": 1500.00,\n  \"details\": \"16GB RAM, 512GB SSD\"\n}"
            },
            "url": {"raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"]}
          }
